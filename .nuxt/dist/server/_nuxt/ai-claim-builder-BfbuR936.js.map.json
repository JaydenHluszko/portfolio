{"file":"ai-claim-builder-BfbuR936.js","mappings":";;;;;;;;;;;;;;;;;;AA+CA,YAAQ;AAAA,MACN,OAAO;AAAA,IAAA,CACR;;;;AAhDM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,6EAAyE,MAAA,CAAA,CAAA,kCAAA;;QAEtE,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;;;cADTC,YAA2B,QAAA,EAArB,OAAM,OAAA,GAAO,GAAC;AAAA,8BAAO,gBAC7B;AAAA,YAAA;AAAA;;;;;;yBAII,CAA0B,GAAAF,QAAAC,UAAA,aAAA;;;;;8BAAhB,OAAK;AAAA,YAAA;AAAA;;;;;yBACf,CAA+B,GAAAD,QAAAC,UAAA,aAAA;;;;;8BAArB,YAAU;AAAA,YAAA;AAAA;;;;;yBACpB,CAA0B,GAAAD,QAAAC,UAAA,aAAA;;;;;8BAAhB,OAAK;AAAA,YAAA;AAAA;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode"],"sources":["../../../../pages/case-studies/ai-claim-builder.vue"],"sourcesContent":["<template>\n  <div class=\"max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20\">\n    <div class=\"max-w-4xl mx-auto\">\n      <NuxtLink to=\"/\" class=\"inline-flex items-center text-primary hover:text-primary-container mb-12 font-sans font-medium transition-colors\">\n        <span class=\"mr-2\">←</span> Back to Home\n      </NuxtLink>\n      \n      <header class=\"mb-16\">\n        <div class=\"flex gap-2 mb-6\">\n          <TechChip>Vue 3</TechChip>\n          <TechChip>WebSockets</TechChip>\n          <TechChip>GenAI</TechChip>\n        </div>\n        <h1 class=\"text-4xl md:text-5xl font-sans font-extrabold text-on-surface mb-6 tracking-tight leading-tight\">AI Claim Builder POC</h1>\n        <p class=\"text-xl text-slate-text font-sans leading-relaxed\">\n          Proof of concept for an AI-assisted claim generation tool with real-time streaming UI.\n        </p>\n      </header>\n\n      <div class=\"w-full h-64 md:h-96 bg-surface-variant rounded-xl mb-16 relative overflow-hidden flex items-center justify-center border border-border-subtle\">\n        <span class=\"text-slate-text font-mono\">Real-time Streaming Interface</span>\n      </div>\n\n      <div class=\"prose prose-invert max-w-none prose-p:text-on-surface-variant prose-headings:text-on-surface prose-a:text-primary\">\n        <h2>The Challenge</h2>\n        <p>Agents needed a faster way to generate complex claims based on unstructured data. The traditional form-based approach was too slow and error-prone.</p>\n        \n        <h2>The Solution</h2>\n        <p>We built a proof of concept using Vue 3 and WebSockets to stream AI-generated claim data directly into the user interface in real-time, allowing agents to edit and approve as it's generated.</p>\n        \n        <h2>Results</h2>\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 my-10 not-prose\">\n          <div class=\"glass-panel p-6 rounded-lg text-center\">\n            <span class=\"block text-3xl font-bold text-primary mb-2\">70%</span>\n            <span class=\"text-sm text-slate-text font-mono\">Faster Time-to-Interactive</span>\n          </div>\n          <div class=\"glass-panel p-6 rounded-lg text-center\">\n            <span class=\"block text-3xl font-bold text-primary mb-2\">3x</span>\n            <span class=\"text-sm text-slate-text font-mono\">More Claims Processed</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nuseHead({\n  title: 'AI Claim Builder POC - Jayden'\n})\n</script>\n"],"version":3}