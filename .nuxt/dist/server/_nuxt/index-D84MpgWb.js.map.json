-2 group-hover:text-primary transition-colors\">{{ title }}</h3>\n      <p class=\"text-slate-text text-sm font-sans mb-6 flex-grow\">{{ description }}</p>\n      <div class=\"flex flex-wrap gap-2 mt-auto mb-4\">\n        <TechChip v-for=\"tech in tags\" :key=\"tech\">{{ tech }}</TechChip>\n      </div>\n      <div class=\"pt-4 border-t border-border-subtle mt-auto\">\n        <span class=\"text-[13px] font-mono text-primary font-medium tracking-[0.05em]\">{{ metric }}</span>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport TechChip from './TechChip.vue'\n\ndefineProps<{\n  title: string\n  description: string\n  tags: string[]\n  metric: string\n}>()\n</script>\n","<template>\n  <div class=\"max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20\">\n    <section class=\"max-w-3xl mb-32\">\n      <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-sans font-extrabold text-on-surface mb-6 tracking-tight leading-tight\">\n        Senior Frontend Engineer & <br class=\"hidden md:block\"/>\n        <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary\">Business Partner.</span>\n      </h1>\n      <p class=\"text-lg text-slate-text font-sans mb-10 leading-relaxed max-w-2xl\">\n        I architect scalable frontend solutions and design systems that bridge the gap between complex engineering and elegant user experiences. Specializing in Vue ecosystem and design system infrastructure.\n      </p>\n      <div class=\"flex gap-4\">\n        <Button variant=\"primary\" size=\"lg\" @click=\"$router.push('/case-studies/growth-driven-redesign')\">View Projects</Button>\n        <Button variant=\"secondary\" size=\"lg\" @click=\"$router.push('/resume')\">Read Resume</Button>\n      </div>\n    </section>\n\n    <section>\n      <h2 class=\"text-2xl font-sans font-semibold text-on-surface mb-12 flex items-center gap-4\">\n        <span class=\"w-8 h-[1px] bg-primary\"></span>\n        Featured Case Studies\n      </h2>\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n        <ProjectCard \n          title=\"Growth-Driven Redesign\" \n          description=\"A complete overhaul of the conversion funnel, restoring layout stability and improving load times.\"\n          :tags=\"['Nuxt 3', 'Tailwind', 'A/B Testing']\"\n          metric=\"24% conversion lift\"\n          @click=\"$router.push('/case-studies/growth-driven-redesign')\"\n        />\n        <ProjectCard \n          title=\"AI Claim Builder POC\" \n          description=\"Proof of concept for an AI-assisted claim generation tool with real-time streaming UI.\"\n          :tags=\"['Vue 3', 'WebSockets', 'GenAI']\"\n          metric=\"70% faster TTI\"\n          @click=\"$router.push('/case-studies/ai-claim-builder')\"\n        />\n        <ProjectCard \n          title=\"Multi-Tenant Design System\" \n          description=\"Architected a core design system supporting 4 distinct brands with CSS variables.\"\n          :tags=\"['CSS Modules', 'Storybook', 'Figma API']\"\n          metric=\"40% less dev time\"\n          @click=\"$router.push('/case-studies/multi-tenant-design-system')\"\n        />\n      </div>\n    </section>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport ProjectCard from '~/components/ProjectCard.vue'\nimport Button from '~/components/Button.vue'\n\nuseHead({\n  title: 'Jayden - Senior Frontend Engineer'\n})\n</script>\n"],"version":3}